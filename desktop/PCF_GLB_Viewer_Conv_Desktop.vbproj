<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>PCF_GLB_Viewer_Conv_Desktop</RootNamespace>
    <AssemblyName>PCF_GLB_Viewer_Conv_Desktop</AssemblyName>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon />
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2792.45" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Native\README_NATIVE_DLL.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
